# ============================================================
# xuexi-habit-app 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env

# ============================================================
# 数据库配置 (PostgreSQL)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xuexi
DB_USER=postgres
DB_PASSWORD=change-me-to-a-strong-password

# 或者使用连接字符串（独立变量优先级更高）
# DATABASE_URL=postgresql://postgres:password@localhost:5432/xuexi

# ============================================================
# JWT 认证
# ============================================================
# 【重要】生产环境必须使用强随机字符串！
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-at-least-64-chars

# ============================================================
# 服务器配置
# ============================================================
PORT=8080
NODE_ENV=development

# ============================================================
# CORS 跨域配置
# ============================================================
# 生产环境必须填写前端实际域名
# ALLOWED_ORIGIN=https://your-frontend-domain.com